# ── MentorBridge Server Environment ──
# Copy to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/mentorbridge
# Or Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/mentorbridge

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
